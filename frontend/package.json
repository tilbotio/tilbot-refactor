{
    "name": "frontend",
    "version": "2.0.0",
    "type": "module",
    "scripts": {
      "dev": "del-cli ./build && cp svelte_server.config.js svelte.config.js && vite dev",
      "build": "cp svelte_server.config.js svelte.config.js && npm run build:vite",
      "build:vite": "vite build",
      "preview": "vite preview",
      "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
      "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
    },
    "devDependencies": {
      "@sveltejs/adapter-auto": "6.0.1",
      "@sveltejs/adapter-static": "^3.0.8",
      "@sveltejs/kit": "2.21.1",
      "@sveltejs/vite-plugin-svelte": "5.0.3",
      "@tailwindcss/line-clamp": "^0.4.4",
      "@types/crypto-js": "^4.1.3",
      "@types/papaparse": "^5.3.16",
      "autoprefixer": "^10.4.21",
      "del-cli": "^5.1.0",
      "postcss": "^8.5.3",
      "svelte": "^5.33.1",
      "svelte-check": "^4.2.1",
      "tailwindcss": "^4.1.7",
      "typescript": "^4.7.4",
      "vite": "^6.3.5"
    },
    "dependencies": {
      "@sveltejs/adapter-node": "^5.2.12",
      "crypto-js": "^4.1.1",
      "daisyui": "^5.0.37",
      "html5-qrcode": "^2.3.8",
      "openai": "^4.102.0",
      "papaparse": "^5.5.3"
    }
  }
